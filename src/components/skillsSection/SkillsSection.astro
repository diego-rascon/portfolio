---
import type { Technology } from "../../types/Skill";
import Section from "../Section.astro";
import Subtitle from "../Subtitle.astro";
import SkillCategoryContainer from "./SkillCategoryContainer.astro";
import TechnologiesList from "./TechnologiesList.astro";

const languages: Technology[] = [
  {
    name: "Java",
    icon: "java",
  },
  {
    name: "JavaScript",
    icon: "javascript",
  },
  {
    name: "TypeScript",
    icon: "typescript",
  },
  {
    name: "Python",
    icon: "python",
  },
];

const frontend: Technology[] = [
  {
    name: "React",
    icon: "react",
  },
  {
    name: "Next.js",
    icon: "nextjs",
  },
  {
    name: "Svelte",
    icon: "svelte",
  },
];

const backend: Technology[] = [
  {
    name: "Spring Boot",
    icon: "spring",
  },
  {
    name: "Node.js",
    icon: "nodejs",
  },
  {
    name: "PostgreSQL",
    icon: "postgresql",
  },
];

const toolsAndInfrastructure: Technology[] = [
  {
    name: "AWS",
    icon: "aws",
  },
  {
    name: "Docker",
    icon: "docker",
  },
  {
    name: "Git",
    icon: "git",
  },
  {
    name: "Figma",
    icon: "figma",
  },
];
---

<Section>
  <Subtitle id="skills" icon="brain">Skills</Subtitle>
  <div class="gap-4 grid md:grid-cols-2 px-4">
    <SkillCategoryContainer
      className="md:col-span-2"
      title="Languages"
      icon="code"
      technologies={languages}
    />
    <SkillCategoryContainer
      title="Front-end"
      icon="layout"
      technologies={frontend}
    />
    <SkillCategoryContainer
      title="Back-end"
      icon="server"
      technologies={backend}
    />
    <SkillCategoryContainer
      className="md:col-span-2"
      title="Tools & Infrastructure"
      icon="infrastructure"
      technologies={toolsAndInfrastructure}
    />
  </div>
</Section>
