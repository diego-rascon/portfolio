---
import type { SkillValue } from "../../types/Skill";

interface Props {
  skills: SkillValue[];
}

const { skills } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    skills.map(({ name, backgroundColor, textColor }) => (
      <div
        class={`${backgroundColor} px-2 rounded-full ${textColor} text-sm shadow-sm saturate-50`}
      >
        {name}
      </div>
    ))
  }
</div>
