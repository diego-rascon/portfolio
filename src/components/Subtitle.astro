---
import type { SvgComponent } from "astro/types";

interface Props {
  Icon: SvgComponent;
}

const { Icon } = Astro.props;
---

<div class="flex items-center gap-3 mb-8 px-4">
  <div
    class="flex justify-center items-center bg-slate-800 shadow border-slate-800 border-t rounded-full size-10"
  >
    <Icon class="size-5 text-sky-300" />
  </div>
  <h2 class="font-semibold text-slate-200 text-2xl tracking-wide">
    <slot />
  </h2>
</div>
